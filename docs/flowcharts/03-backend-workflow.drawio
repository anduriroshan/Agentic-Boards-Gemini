<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0">
  <diagram name="Backend Workflow" id="backend-workflow">
    <mxGraphModel dx="1100" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Endpoints Subgraph -->
        <mxCell id="grp_endpoints" value="API Endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=13;spacingTop=5;dashed=1;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="130" y="30" width="580" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="chatep" value="POST /api/chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="grp_endpoints">
          <mxGeometry x="20" y="40" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="liveep" value="WS /api/agent/live" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="grp_endpoints">
          <mxGeometry x="210" y="40" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="authep" value="/auth/*&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(Google OAuth)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;" vertex="1" parent="grp_endpoints">
          <mxGeometry x="410" y="40" width="140" height="45" as="geometry"/>
        </mxCell>

        <!-- OAuth flow (branching right) -->
        <mxCell id="oauth" value="Google OAuth 2.0&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;→ Create User + Session&lt;br&gt;→ Set Cookie + Redirect&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="700" y="190" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="sqlite" value="SQLite DB&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(Users, Sessions, Workspaces)&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;size=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="310" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_auth_oauth" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="authep" target="oauth" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_oauth_sqlite" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="oauth" target="sqlite" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Validate Session -->
        <mxCell id="validate" value="Validate Session Cookie" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="290" y="195" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_chat_val" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="chatep" target="validate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_live_val" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="liveep" target="validate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Build AgentState -->
        <mxCell id="buildstate" value="Build AgentState&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;(messages, tiles, provider)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="290" y="295" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_val_build" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="validate" target="buildstate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Invoke Agent -->
        <mxCell id="invoke" value="Invoke LangGraph / ADK Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="400" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_build_invoke" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="buildstate" target="invoke" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stream back decision -->
        <mxCell id="streamback" value="Stream results back" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="310" y="500" width="140" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e_invoke_stream" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="invoke" target="streamback" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SSE events -->
        <mxCell id="sseevents" value="metadata, query,&lt;br&gt;visualization, data_table,&lt;br&gt;kpi_tile, agent_step, done" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="640" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_stream_sse" value="SSE events&#xa;(text chat)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;html=0;" edge="1" source="streamback" target="sseevents" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- WebSocket events -->
        <mxCell id="wsevents" value="tool results,&lt;br&gt;audio chunks,&lt;br&gt;turn state updates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="440" y="640" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_stream_ws" value="WebSocket frames&#xa;(voice)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;html=0;" edge="1" source="streamback" target="wsevents" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Frontend -->
        <mxCell id="client" value="Frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="310" y="760" width="140" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_sse_client" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="sseevents" target="client" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ws_client" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="wsevents" target="client" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
