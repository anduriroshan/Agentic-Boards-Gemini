# ── LLM ──
# Mode: "passthrough" (OpenAI-compatible, api-key) or "custom" (proprietary + OAuth2) or "gemini"
LLM_MODE=passthrough

# Pass-through mode (OpenAI-compatible — just api-key, no OAuth)
LLM_API_KEY=<your-api-key>
LLM_BASE_URL=<your-gateway-url-for-passthrough>
LLM_MODEL=gpt-4.1-mini

# Custom mode (Proprietary ChatCompletion + Azure AD OAuth2)
# Only needed when LLM_MODE=custom
LLM_TENANT_ID=<your-tenant-id>
LLM_CLIENT_ID=<your-client-id>
LLM_CLIENT_SECRET=<your-client-secret>
LLM_AUTH_SCOPE=<your-auth-scope>
LLM_API_URL=<your-gateway-url-for-custom>
LLM_USER_ID=<your-user-id>

# OpenAI direct mode (set LLM_MODE=openai to use)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini mode (set LLM_MODE=gemini to use)
GEMINI_API_KEY=<API KEY>
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Databricks ──
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=<pat-token>
DATABRICKS_CLUSTER_ID=<cluster-id>
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=
DATABRICKS_DEFAULT_TABLE=
DATABRICKS_INDEX_TABLES=

# ── Milvus (local vector DB) ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ENABLED=true

# ── Cube.js ──
CUBEJS_API_URL=http://localhost:4000/cubejs-api/v1
CUBEJS_API_SECRET=<cube-api-secret>
CUBEJS_DB_TYPE=databricks-jdbc
CUBEJS_DB_DATABRICKS_URL=jdbc:databricks://<host>:443/default;transportMode=http;ssl=1;AuthMech=3;httpPath=<http-path>
CUBEJS_DB_DATABRICKS_TOKEN=<pat-token>

# ── Backend ──
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./agentic_bi.db

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000
