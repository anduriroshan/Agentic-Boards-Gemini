# ── LLM ──
# Mode: "openai" or "gemini"
LLM_MODE=gemini
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini mode (set LLM_MODE=gemini to use)
# This model is specifically required for the Multimodal Live API (ADK)
GEMINI_MODEL=gemini-live-2.5-flash-native-audio

# ── Google Cloud / Vertex AI ──
# This key is used for Gemini / Vertex AI Live API (ADK)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT=

# ── BigQuery ──
# BigQuery requires a Service Account JSON for full access.
# If you have a service_account.json, place it in the backend folder and set:
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
BIGQUERY_PROJECT_ID=
BIGQUERY_DEFAULT_TABLE=

# ── Databricks ──
# Connection: HTTP_PATH (SQL Warehouse) takes priority over CLUSTER_ID (Spark cluster).
# Leave a field empty to skip that mode.
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# SQL Warehouse mode (serverless — no cluster needed)
DATABRICKS_HTTP_PATH=

# Spark / Cluster mode (leave empty if using SQL Warehouse)
DATABRICKS_CLUSTER_ID=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=
DATABRICKS_DEFAULT_TABLE=
DATABRICKS_INDEX_TABLES=

# ── Auth & Domain ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_URL=
DOMAIN_NAME=
SESSION_SECRET=
ALLOWED_ORIGINS=

# ── DNS / Custom Domain (Cloudflare Automation) ──
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ── Milvus (Vector DB) ──
MILVUS_URI=./data/milvus_data.db
MILVUS_ENABLED=true

# ── Cube.js ──
CUBEJS_API_URL=
CUBEJS_API_SECRET=

# ── Backend & Frontend ──
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/agentic_bi.db
VITE_API_BASE_URL=
