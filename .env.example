# ── LLM ──
# Mode: "passthrough" (OpenAI-compatible, api-key) or "custom" (proprietary + OAuth2)
LLM_MODE=passthrough

# Pass-through mode (OpenAI-compatible — just api-key, no OAuth)
LLM_API_KEY=<your-api-key>
LLM_BASE_URL=https://apigatewayazeu.accenture.com/genai/stage/lbpass/
LLM_MODEL=gpt-4.1-mini

# Custom mode (Accenture proprietary ChatCompletion + Azure AD OAuth2)
# Only needed when LLM_MODE=custom
LLM_TENANT_ID=f3211d0e-125b-42c3-86db-322b19a65a22
LLM_CLIENT_ID=<your-client-id>
LLM_CLIENT_SECRET=<your-client-secret>
LLM_AUTH_SCOPE=api://e053b11b-8480-4abf-9c64-a2e23be62ff5/.default
LLM_API_URL=https://apigatewayazeu.accenture.com/genai/stage/interaction/api/v1/Client/7a4a8864-0e44-41a4-9181-b50fbcdfd2bd/Engine/576E5532-31F4-40A9-B8B0-48EF68553B8C/Model/9c530a7f-e6d4-411d-adb1-f0d2a3073b7f/ChatCompletion
LLM_USER_ID=2403

# ── Databricks ──
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_TOKEN=<pat-token>
DATABRICKS_CLUSTER_ID=<cluster-id>
DATABRICKS_CATALOG=variance
DATABRICKS_SCHEMA=analysis_v2
DATABRICKS_DEFAULT_TABLE=variance.analysis_v2.gold_variancesummary_03
DATABRICKS_INDEX_TABLES=variance.analysis_v2.gold_variancesummary_03,variance.analysis_v2.coa_hierarchy

# ── Milvus (local vector DB) ──
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ENABLED=true

# ── Cube.js ──
CUBEJS_API_URL=http://localhost:4000/cubejs-api/v1
CUBEJS_API_SECRET=<cube-api-secret>
CUBEJS_DB_TYPE=databricks-jdbc
CUBEJS_DB_DATABRICKS_URL=jdbc:databricks://<host>:443/default;transportMode=http;ssl=1;AuthMech=3;httpPath=<http-path>
CUBEJS_DB_DATABRICKS_TOKEN=<pat-token>

# ── Backend ──
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./agentic_bi.db

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000
